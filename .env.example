# Zabbix — подключение к платформе мониторинга.
# Скопируй этот файл в .env и подставь реальные значения.
# .env в git НЕ коммитится (см. .gitignore).

# --- Zabbix (обязательно) ---
# Базовый URL без завершающего слэша и без /api_jsonrpc.php.
# Пример: http://192.0.2.10  или  http://zabbix.example.local
ZABBIX_URL=http://192.0.2.10
# API-токен (Zabbix → User → API tokens). 64-символьный hex.
ZABBIX_TOKEN=your_zabbix_api_token_64hex
# Group ID группы хостов, по которой мониторим (целое число).
# Узнать: hostgroup.get → найти нужную → groupid.
ZABBIX_GROUP_ID=1

# --- Специфика объекта (НЕ хардкодим в коде — только здесь) ---
# Префикс кода точки в имени хоста Zabbix. Имя вида "<Объект> - Ряд X AP01 (PREFIX3)".
# По нему коллектор отличает AP (есть код) от коммутаторов/шлюза (кода нет).
# Пусто = автоопределение AP не работает.
HOST_CODE_PREFIX=AP
# Отображаемое имя объекта (тема писем + заголовок веб-карты). Дефолт — генерик.
SITE_NAME=Мониторинг Wi-Fi

# --- Email-нотификатор (опционально) ---
# Если НЕ задать SMTP_HOST/SMTP_FROM/SMTP_TO — нотификатор логирует
# «would notify» и не шлёт писем (прогон при этом работает нормально).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true для 465 (implicit TLS)
# SMTP_USER=alerts@example.com
# SMTP_PASS=your_password
# SMTP_FROM=alerts@example.com # по умолчанию = SMTP_USER
# SMTP_TO=operator@example.com
# Адрес хелпдеска для писем о падении/восстановлении точек Wi-Fi (req v0.6).
# По умолчанию = SMTP_TO. Отправка так же gated: без SMTP — лог «would notify».
# HELPDESK_TO=helpdesk@example.com

# --- История точек для админ-панели (v0.6) ---
# Сколько дней хранить историю метрик/событий (прунинг каждый прогон коллектора).
# METRICS_HISTORY_DAYS=90
# Порог «массового отключения»: клиентов было >= N и стало 0 за один шаг —
# признак проблемы самой точки, а не естественного ухода людей.
# CLIENT_DROP_THRESHOLD=3

# --- Веб-карта заказчика (server/, на этой же машине) ---
# Ключ Yandex Maps JS API. Виден в браузере (норма для JS API), но в репо не
# коммитим. ОБЯЗАТЕЛЬНО ограничить ключ по домену-referer в кабинете Яндекса.
YANDEX_API_KEY=your_yandex_js_api_key
# Адрес и порт веб-сервера. 0.0.0.0 — слушать на всех интерфейсах (доступ по
# локальной сети/домену); 127.0.0.1 — только локально.
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Время жизни сессии (часы).
WEB_SESSION_TTL_HOURS=12
# Ставить true ТОЛЬКО когда сервер за HTTPS (домен/обратный прокси). По HTTP
# флаг Secure ломает cookie и логин не пройдёт.
WEB_SECURE_COOKIE=false
# Старше скольки секунд данные считаются устаревшими (коллектор ходит ~5 мин).
# WEB_STALE_AFTER_SEC=720
# Центр и зум карты по умолчанию (когда points.json пуст). Координаты объекта —
# специфика заказчика, поэтому здесь, а не в коде. Дефолт — нейтральный центр РФ.
MAP_CENTER_LAT=55.751
MAP_CENTER_LON=37.618
MAP_ZOOM=17
