# Секреты — реальные креды (Zabbix-токен, SMTP, Яндекс-ключ)
.env
.env.bak

# Рантайм — состояние точек, логи, отчёты
state/
logs/
reports/

# Зависимости
node_modules/

# Рабочие правила агента — только локально, на гит не уходят
.claude rules/

# Внутренняя/привязанная к заказчику документация и данные — только локально.
# Публичным остаётся генерик-README.md; реальные значения берутся из .env.
# (комментарии — отдельной строкой: в .gitignore нет trailing-комментариев!)
# контекст с названием/городом/структурой сети заказчика:
CLAUDE.md
# план продукта + каталог данных Zabbix (привязка к объекту):
docs/
# реальные координаты точек заказчика (см. geo.txt.example):
geo.txt
# генерится из geo.txt — раскрывает раскладку AP:
public/points.json

# Мусор ОС и редакторов
*.bak
*.tmp
nul
Thumbs.db
Desktop.ini
.DS_Store
