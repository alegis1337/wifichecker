{
  "name": "rinok-wifi-monitor",
  "version": "0.6.0",
  "private": true,
  "description": "Мониторинг Wi-Fi точек рынка через Zabbix API + веб-карта заказчика (сбор, SQLite, оповещения, карта)",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/index.js",
    "once": "node --disable-warning=ExperimentalWarning src/index.js --once",
    "debug": "node --disable-warning=ExperimentalWarning src/index.js --debug",
    "test-email": "node --disable-warning=ExperimentalWarning src/index.js --test",
    "web": "node --disable-warning=ExperimentalWarning server/app.js",
    "add-user": "node --disable-warning=ExperimentalWarning server/add-user.js",
    "build-points": "node tools/build-points.js"
  },
  "dependencies": {
    "nodemailer": "^6.9.16"
  }
}
